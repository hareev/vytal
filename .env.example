# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# Claude AI — required for AI health diagnosis
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API server URL (defaults to http://localhost:3001 if not set)
VITE_API_URL=http://localhost:3001

# Set to "true" to run without a backend (uses in-memory mock data)
VITE_USE_MOCK=true

# Optional: override the default Claude model
# VITE_CLAUDE_MODEL=claude-sonnet-4-20250514


# ── API Server ────────────────────────────────────────────────────────────────

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/vytal?sslmode=require

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-string

# CORS allowed origin (defaults to * in dev)
# CORS_ORIGIN=https://your-frontend-domain.com

# API server port (default: 3001)
# PORT=3001
